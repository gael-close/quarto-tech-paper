##---------------------------------------------------
## Remove autosaves generated by the Matlab editor
## We have git for backups!
##---------------------------------------------------

.env

# hidden and backup files
.*
*~*
!.gitignore
!.gitkeep
!.gitattributes
!.gitlab-ci.yml
!.python-version
!.github
!.envrc
!.env.example

# Python
__pycache__/
*.pyc
*egg-info/

# Ignore generated directories and other repo build, CVS, gdrive ..
_plots/
*_files/
_build/
tmp/
manuscript/manuscript.pdf
